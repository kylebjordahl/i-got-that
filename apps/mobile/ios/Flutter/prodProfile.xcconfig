#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.release.xcconfig"
#include "Generated.xcconfig"

ASSET_PREFIX=prod
BUNDLE_NAME=IGT
BUNDLE_DISPLAY_NAME=IGT

// Native Sign in with Google (prod). Fill in once the prod iOS OAuth client
// exists in the Cloud Console (bundle id com.kylebjordahl.igt) — see
// docs/AUTH.md's Google section. Empty ⇒ native Google sign-in fails at
// runtime with a clear "no client ID" error (web flow is unaffected).
GOOGLE_IOS_CLIENT_ID=503268168924-gk8d4c4dfjtkmi2ol3t63usi089h1uvv.apps.googleusercontent.com
GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.503268168924-gk8d4c4dfjtkmi2ol3t63usi089h1uvv
